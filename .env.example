# -----------------------------------------------------------------------------
# Agent runtime
# -----------------------------------------------------------------------------
# Explicit session id override (also accepted via --session-id CLI flag).
# Normally you do NOT need to set this — the agent auto-generates a semantic id
# like `alice-my-project-20260417` from your active gcloud account/project and
# auto-resumes the last session. Only set this when you want a fixed label
# (e.g. shared CI runs, scripted scenarios).
# DEVOPS_SESSION_ID=shared-ci-session

# Override where conversation state and the session registry are stored.
# Defaults to $XDG_CONFIG_HOME/agent-devops (i.e. ~/.config/agent-devops).
# XDG_CONFIG_HOME=/custom/path

# Log verbosity. DEBUG | INFO | WARNING | ERROR | CRITICAL
LOG_LEVEL=INFO

# Log output format:
#   auto   (default) — pretty colored lines in a TTY, JSON everywhere else
#   pretty          — always human-readable (force colors even when piped)
#   json            — always structured JSON (Cloud Logging `jsonPayload` shape)
# LOG_FORMAT=auto

# Set to any value to disable ANSI colors in pretty mode.
# NO_COLOR=1

# -----------------------------------------------------------------------------
# Google Cloud (ADC-based authentication — Zero-Trust standard)
# -----------------------------------------------------------------------------
# Run `gcloud auth application-default login` BEFORE starting the agent.
# Do NOT set GOOGLE_APPLICATION_CREDENTIALS to a local JSON key file — that
# pattern is discouraged; use ADC or an attached service account instead.
#
# Set the default project for GCP SDK calls:
GOOGLE_CLOUD_PROJECT=your-gcp-project-id

# Optional: override the default quota project for ADC.
# GOOGLE_CLOUD_QUOTA_PROJECT=your-gcp-project-id

# -----------------------------------------------------------------------------
# AWS (only if you will use the AWS tools)
# -----------------------------------------------------------------------------
# Prefer AWS SSO (`aws sso login`) or an IAM role; do not paste long-lived keys here.
AWS_PROFILE=default
AWS_REGION=us-east-1

# -----------------------------------------------------------------------------
# Observability (optional — OpenTelemetry + Google Cloud Trace)
# -----------------------------------------------------------------------------
# Set to "true" to export traces to Cloud Trace. Requires
# `opentelemetry-sdk` and `opentelemetry-exporter-gcp-trace` installed plus a
# valid ADC-authenticated project (GOOGLE_CLOUD_PROJECT above).
OTEL_ENABLED=false

# Service name attached to each span (default: agent-devops).
# OTEL_SERVICE_NAME=agent-devops

# -----------------------------------------------------------------------------
# LLM provider — Gemini via Vertex AI (recommended, Zero-Trust)
# -----------------------------------------------------------------------------
# No API key needed. Authentication flows through the same ADC you already set
# above with `gcloud auth application-default login`. Your corporate identity
# (e.g. alice@example.com) is used to call Vertex AI, so every inference call
# lands in Cloud Audit Logs tied to a real user and any 2FA / hardware key on
# your corporate account implicitly protects the model access.
#
# Prerequisites on GOOGLE_CLOUD_PROJECT:
#   gcloud services enable aiplatform.googleapis.com --project=$GOOGLE_CLOUD_PROJECT
#   gcloud projects add-iam-policy-binding $GOOGLE_CLOUD_PROJECT \
#     --member="user:you@example.com" --role="roles/aiplatform.user"
GOOGLE_GENAI_USE_VERTEXAI=true
GOOGLE_CLOUD_LOCATION=us-east1

# -----------------------------------------------------------------------------
# LLM provider — alternative API-key backends (dev / fallback only)
# -----------------------------------------------------------------------------
# Uncomment ONE of these ONLY if you cannot use Vertex AI. All three use static
# secrets and break the Zero-Trust posture — prefer Vertex AI above.
#
# Google AI Studio (Gemini API, consumer tier — separate from your GCP billing):
#   Generate at https://aistudio.google.com/apikey
# GEMINI_API_KEY=AIza...
#
# Anthropic Claude:
# ANTHROPIC_API_KEY=sk-ant-...
#
# OpenAI:
# OPENAI_API_KEY=sk-...
